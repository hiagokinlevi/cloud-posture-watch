PROVIDER=aws  # aws, azure, gcp
AWS_PROFILE=default
AWS_REGION=us-east-1
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# Assessment configuration
BASELINE_PROFILE=standard  # minimal, standard, strict
INCLUDE_LOGGING_CHECKS=true
INCLUDE_ENCRYPTION_CHECKS=true
INCLUDE_BACKUP_CHECKS=true
DRIFT_SENSITIVITY=medium
OUTPUT_DIR=./output
REPORT_VERBOSITY=standard
