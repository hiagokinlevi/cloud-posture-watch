# cloud-posture-watch environment template
# Copy to .env and adjust values for your environment.

# -----------------------------
# Scanner execution parameters
# -----------------------------
# Set to true to enable continuous watch mode; false for one-shot scans.
CPW_WATCH_MODE=false

# Interval between scans when watch mode is enabled (seconds).
CPW_SCAN_INTERVAL_SECONDS=900

# Baseline profile to use (minimal|standard|strict).
CPW_BASELINE_PROFILE=standard

# Comma-separated providers to scan.
# Supported values typically include: aws,azure,gcp
CPW_PROVIDERS=aws,azure,gcp

# Output format for generated report artifacts.
# Supported by CLI: markdown|json|both (if supported in your version)
CPW_OUTPUT_FORMAT=both

# -----------------------------
# Report + storage settings
# -----------------------------
# Local directory inside container/host where reports are written.
CPW_REPORT_DIR=./reports

# Storage backend for report persistence.
# local = filesystem only
# s3    = upload to AWS S3
# gcs   = upload to Google Cloud Storage
# azure = upload to Azure Blob Storage
CPW_STORAGE_BACKEND=local

# Backend target identifiers (set only what you use).
CPW_S3_BUCKET=
CPW_GCS_BUCKET=
CPW_AZURE_CONTAINER=

# Optional common prefix/path for uploaded report keys/blobs.
CPW_STORAGE_PREFIX=cloud-posture-watch

# -----------------------------
# AWS credentials / region
# -----------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# -----------------------------
# Azure credentials
# -----------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# -----------------------------
# GCP credentials
# -----------------------------
# Option 1: path to mounted service account JSON in container
GOOGLE_APPLICATION_CREDENTIALS=/app/creds/gcp-service-account.json
# Option 2: raw JSON credential content (if your runtime supports it)
GCP_SERVICE_ACCOUNT_JSON=

# -----------------------------
# Optional notifications/webhook
# -----------------------------
CPW_WEBHOOK_URL=
CPW_WEBHOOK_PROVIDER=
